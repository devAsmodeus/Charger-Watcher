# --- Telegram ---
TG_BOT_TOKEN=

# --- Database ---
POSTGRES_USER=charger
POSTGRES_PASSWORD=charger
POSTGRES_DB=charger
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://charger:charger@postgres:5432/charger

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Upstream EV charging provider API ---
# Base URL of the provider's API gateway.
# (The actual URL is private — see your deployment notes.)
API_BASE=https://api.example.com

# Optional DNS override: when the host network cannot resolve API_BASE's
# hostname (e.g. VPN kill-switch blocks direct DNS), set these to route
# requests through extra_hosts in docker-compose without hard-coding
# the target in git-tracked files.
#   API_HOST = hostname part of API_BASE (without scheme)
#   API_HOST_IP = IP to resolve it to
API_HOST=
API_HOST_IP=
# Optional: origin/referer header the upstream expects (e.g. their own web app).
API_ORIGIN=
# Identify yourself honestly — recommended to include a contact email.
API_USER_AGENT=charger-watcher/0.1 (+contact@example.com)

# Poll interval for bulk network status (seconds)
POLL_INTERVAL_SEC=10
# How often to re-sync the location catalog (coords only, rarely changes), seconds
CATALOG_SYNC_INTERVAL_SEC=300
# How often the SSE manager re-reads subscriptions to open/close streams, seconds
SSE_SYNC_INTERVAL_SEC=15
# HTTP timeout in seconds
HTTP_TIMEOUT_SEC=15
# Optional SOCKS5/HTTP proxy to reach the provider API (for non-BY hosts).
HTTP_PROXY_URL=

# --- Notifier ---
# Delay (seconds) between notifying paid and free subscribers
FREE_TIER_NOTIFY_DELAY_SEC=120
# Max subscriptions per tier
FREE_TIER_MAX_SUBSCRIPTIONS=1
PAID_TIER_MAX_SUBSCRIPTIONS=5
# Don't re-notify the same user about the same location more often than this
NOTIFY_COOLDOWN_SEC=600
# How often the expired-tier reaper runs, seconds
TIER_REAPER_INTERVAL_SEC=3600
# Max outbound Telegram messages per second (Telegram limit: ~30/s global)
TG_SEND_RATE_PER_SEC=20

# --- Payments (Telegram Stars: no provider token needed) ---
PAID_TIER_PRICE_STARS=150
PAID_TIER_DURATION_DAYS=30

# --- Logging ---
LOG_LEVEL=INFO
